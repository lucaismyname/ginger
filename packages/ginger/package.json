{
  "name": "@lucaismyname/ginger",
  "version": "0.0.11",
  "description": "A headless React audio player",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./waveform": {
      "types": "./dist/waveform/index.d.ts",
      "import": "./dist/waveform/index.js",
      "require": "./dist/waveform/index.cjs"
    },
    "./experimental-gapless": {
      "types": "./dist/experimental-gapless/index.d.ts",
      "import": "./dist/experimental-gapless/index.js",
      "require": "./dist/experimental-gapless/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "react",
    "audio",
    "player",
    "headless",
    "playlist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucaismyname/ginger"
  }
}
