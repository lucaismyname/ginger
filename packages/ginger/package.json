{
  "name": "@lucaismyname/ginger",
  "version": "0.0.50",
  "description": "A headless React audio-player primitive",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs", 
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs"
    },
    "./waveform": {
      "types": "./dist/waveform/index.d.ts",
      "import": "./dist/waveform/index.js",
      "require": "./dist/waveform/index.cjs"
    },
    "./experimental-gapless": {
      "types": "./dist/experimental-gapless/index.d.ts",
      "import": "./dist/experimental-gapless/index.js",
      "require": "./dist/experimental-gapless/index.cjs"
    },
    "./equalizer": {
      "types": "./dist/equalizer/index.d.ts",
      "import": "./dist/equalizer/index.js",
      "require": "./dist/equalizer/index.cjs"
    },
    "./spatial": {
      "types": "./dist/spatial/index.d.ts",
      "import": "./dist/spatial/index.js",
      "require": "./dist/spatial/index.cjs"
    },
    "./transcript": {
      "types": "./dist/transcript/index.d.ts",
      "import": "./dist/transcript/index.js",
      "require": "./dist/transcript/index.cjs"
    },
    "./remote": {
      "types": "./dist/remote/index.d.ts",
      "import": "./dist/remote/index.js",
      "require": "./dist/remote/index.cjs"
    },
    "./crossfade": {
      "types": "./dist/crossfade/index.d.ts",
      "import": "./dist/crossfade/index.js",
      "require": "./dist/crossfade/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "docs:api": "typedoc --options typedoc.json",
    "check-bundle": "node scripts/check-bundle-size.mjs",
    "verify:release": "npm run build && npm run test && npm run typecheck && npm run lint && npm run check-bundle",
    "prepublishOnly": "npm run verify:release"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typedoc": "^0.28.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "react",
    "audio",
    "player",
    "headless",
    "playlist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucaismyname/ginger"
  }
}
