# Absolute site URL for canonical and og:url (no trailing slash).
# Defaults to the GitHub repository URL if unset.
# VITE_SITE_URL=https://your-domain.example

# Full URL for og:image/twitter:image. If unset, the build uses
# `${VITE_SITE_URL}/og.jpg` when the site URL is not the default GitHub repo URL;
# otherwise it uses a raw.githubusercontent.com URL for the committed public/og.jpg.
# VITE_OG_IMAGE_URL=https://your-domain.example/og.jpg
